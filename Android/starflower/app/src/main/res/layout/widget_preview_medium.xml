<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/widget_preview_bg"
    android:padding="16dp"
    android:gravity="center_vertical">
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="수원시" android:textColor="#CCFFFFFF" android:textSize="14sp" />
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="6dp" android:baselineAligned="false">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="72" android:textColor="#FFFFFFFF" android:textSize="54sp" android:fontFamily="sans-serif-thin" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="%" android:textColor="#D9FFFFFF" android:textSize="22sp" android:layout_marginTop="9dp" />
        </LinearLayout>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="관측하기 좋아요" android:textColor="#D9FFFFFF" android:textSize="12sp" android:layout_marginTop="5dp" />
    </LinearLayout>
    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
        android:gravity="end" android:text="🌙  달·월출월몰·상세"
        android:textColor="#99FFFFFF" android:textSize="12sp" android:layout_marginStart="16dp" />
</LinearLayout>