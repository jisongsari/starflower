<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_preview_bg"
    android:padding="16dp"
    android:gravity="center_vertical">

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="수원시" android:textColor="#CCFFFFFF" android:textSize="15sp"
        android:fontFamily="@font/pretendard_semibold" />

    <LinearLayout
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp" android:baselineAligned="false">
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="72" android:textColor="#FFFFFFFF" android:textSize="64sp"
            android:fontFamily="@font/pretendard_thin" />
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="%" android:textColor="#D9FFFFFF" android:textSize="24sp"
            android:layout_marginTop="10dp" android:fontFamily="@font/pretendard_regular" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:layout_marginTop="4dp">
        <ImageView
            android:layout_width="15dp" android:layout_height="15dp"
            android:src="@drawable/ic_w_clear" android:layout_marginEnd="5dp" />
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="관측하기 좋아요" android:textColor="#D9FFFFFF" android:textSize="13sp"
            android:fontFamily="@font/pretendard_medium" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="기온 12° · 21:30" android:textColor="#8CFFFFFF" android:textSize="11sp"
        android:layout_marginTop="8dp" android:fontFamily="@font/pretendard_medium" />
</LinearLayout>