<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/widget_preview_bg"
    android:padding="16dp"
    android:gravity="center_vertical">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="수원시" android:textColor="#CCFFFFFF" android:textSize="15sp" />
    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginTop="8dp" android:baselineAligned="false">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="72" android:textColor="#FFFFFFFF" android:textSize="60sp" android:fontFamily="sans-serif-thin" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="%" android:textColor="#D9FFFFFF" android:textSize="24sp" android:layout_marginTop="10dp" />
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="관측하기 좋아요" android:textColor="#D9FFFFFF" android:textSize="13sp" android:layout_marginTop="4dp" />
</LinearLayout>